---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = 'Augusto Mercurio';
const description = 'Visual Designer com experiência em UI/UX e Marketing.';
const permalink = Astro.site?.href || 'https://amercurio.com.br';
---

<BaseLayout title={title} description={description} permalink={permalink}>
  <div class="home-container">
    <div class="home-copy">
      <h1>Augusto Mercurio</h1>
      <p>No passado, trabalhei com marketing, criando campanhas de alcance nacional para clientes líderes de mercado no cenário nacional.</p>
      <p>Pelo caminho, construí um Design System que modernizou um CRM com 20 anos de legado que estava perdendo espaço para outras ferramentas.</p>
      <p>Recentemente, pude aplicar toda a minha experiência de design para liderar um projeto de CreativeOps em uma empresa global líder em nutrição de plantas.</p>
    </div>

    <div class="hero-image-container">
      <picture>
        <source srcset="/assets/avatar.webp" media="(min-width: 100px)">
        <img class="hero-image" alt="Retrato de um jovem de pele branca com uma expressão facial de surpresa." src="/assets/avatar.webp">
      </p>
    </div>
  </div>
</BaseLayout>

<style>
  .home-container {
    align-items: top;
    display: flex;
    flex: 1;
    justify-content: center;
    margin: 2em 0;
    min-height: 100px;
  }

  .home-copy {
    flex: 1;
    padding: 0 1em;
  }

  .home-copy h1 {
    font-size: 4rem;
    margin-bottom: 0.5em;
    line-height: 4rem;
  }

  .home-copy p {
    font-size: 1rem;
  }

  .hero-image-container {
    margin: 0 1em;
    text-align: center;
  }

  .hero-image-container picture {
    display: block;
    min-height: 250px;
  }

  .caption {
    font-size: .8em;
    font-style: italic;
    text-align: left;
  }

  .hero-image {
    width: 100%;
    max-width: 600px;
    margin-bottom: 1em;
  }

  @media (max-width: 90rem) {
    p {
      font-size: 1rem;
    }

    .hero-image {
      max-width: 600px;
    }
  }

  @media (max-width: 1000px) {
    .home-container {
      flex-direction: column;
    }

    .home-copy {
      flex: 0;
      padding-bottom: 2em;
      text-align: center;
    }
  }
</style>
